{{ if ne .chezmoi.os "windows" -}}
#!/bin/bash
set -euo pipefail

# Activate mise and install tool versions from .mise.toml
export PATH="${HOME}/.local/bin:${PATH}"

if ! command -v mise >/dev/null 2>&1; then
  echo "mise not found, skipping tool installation"
  exit 0
fi

echo "Installing tool versions via mise..."
if ! mise install --yes; then
  echo "" >&2
  echo "========================================" >&2
  echo "WARNING: mise install が一部失敗しました" >&2
  echo "========================================" >&2
  echo "原因: GitHub API レート制限、ネットワーク障害など" >&2
  echo "" >&2
  echo "未インストールのツールを確認:" >&2
  echo "  mise ls --missing" >&2
  echo "" >&2
  echo "リトライ:" >&2
  echo "  mise install" >&2
  echo "========================================" >&2
fi
{{ end -}}
