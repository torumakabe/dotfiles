{{ if ne .chezmoi.os "windows" -}}
#!/bin/bash
set -euo pipefail

# Activate mise and install tool versions from config
# Order dependency:
# - Keep this after run_once_before_20-install-mise because `mise` must already exist.
# - Keep this in the `after_` phase because chezmoi must first apply
#   ~/.config/mise/config.toml and ~/.config/mise/mise.lock.
# - Keep run_once_after_30-install-tools after this script because it relies on runtimes
#   and shims installed by `mise install`.
export PATH="${HOME}/.local/bin:${PATH}"

if ! command -v mise >/dev/null 2>&1; then
  echo "mise not found, skipping tool installation"
  exit 0
fi

{{ if and .devcontainer (not .codespaces) -}}
# Dev container (非 Codespaces): コンテナ作成時は GitHub API トークンが
# 利用できずレート制限に抵触するため、mise install はスキップする。
# コンテナ作成後にターミナルから手動で実行:
#   mise install --yes
echo "Dev container detected — skipping mise install"
echo "Run 'mise install --yes' manually after container creation"
exit 0
{{ end -}}

max_attempts=3
attempt=1
wait_sec=10

retry_missing_tools_without_github_credentials() {
  # --- SAML SSO workaround ---
  # Codespaces can inject GITHUB_TOKEN automatically. When a public GitHub Organization
  # repository also requires SAML SSO, authenticated requests can fail with 403 even
  # though the same asset is downloadable anonymously. Retry only the still-missing
  # tools without GitHub credentials.
  #
  # Revisit/remove this block when either:
  # - Codespaces no longer exposes a token that triggers the SAML-only 403 behavior, or
  # - mise / the affected registries can complete these downloads with the token present.
  #
  # When changing this logic, verify on Codespaces that:
  # - the initial authenticated `mise install --yes` still runs first,
  # - only missing tools are retried unauthenticated, and
  # - non-Codespaces environments still keep their existing behavior.
  local missing_for_retry
  missing_for_retry="$(mise ls --missing 2>/dev/null | awk '/(missing)/ {print $1}' || true)"
  if [ -z "$missing_for_retry" ]; then
    return 0
  fi

  echo ""
  echo "Retrying missing tools without GitHub credentials (SAML SSO workaround)..."
  (
    unset GITHUB_TOKEN GH_TOKEN MISE_GITHUB_TOKEN 2>/dev/null || true
    echo "$missing_for_retry" | while read -r tool; do
      [ -z "$tool" ] && continue
      echo "  Installing $tool (unauthenticated)..."
      mise install "$tool" --yes 2>&1 || true
    done
  )
}

echo "Installing tool versions via mise..."
while [ "$attempt" -le "$max_attempts" ]; do
  if mise install --yes 2>&1; then
    echo "mise install completed successfully"
    break
  fi

  missing_count="$(mise ls --missing 2>/dev/null | grep -c '(missing)' || true)"
  if [ "$missing_count" -eq 0 ]; then
    echo "All tools installed successfully"
    break
  fi

  if [ "$attempt" -lt "$max_attempts" ]; then
    echo "Attempt ${attempt}/${max_attempts}: ${missing_count} tool(s) remaining. Retrying in ${wait_sec}s..."
    sleep "$wait_sec"
    wait_sec=$((wait_sec * 2))
  fi

  attempt=$((attempt + 1))
done

retry_missing_tools_without_github_credentials

# 最終チェック
missing_tools="$(mise ls --missing 2>/dev/null || true)"
if echo "$missing_tools" | grep -q '(missing)'; then
  echo "" >&2
  echo "========================================" >&2
  echo "WARNING: mise install が一部失敗しました" >&2
  echo "========================================" >&2
  echo "$missing_tools" >&2
  echo "" >&2
  echo "リトライ: mise install" >&2
  echo "========================================" >&2
fi
{{ end -}}
