{{ if ne .chezmoi.os "windows" -}}
#!/bin/bash
set -euo pipefail

# Activate mise and install tool versions from config
export PATH="${HOME}/.local/bin:${PATH}"

if ! command -v mise >/dev/null 2>&1; then
  echo "mise not found, skipping tool installation"
  exit 0
fi

{{ if and .devcontainer (not .codespaces) -}}
# Dev container (非 Codespaces): コンテナ作成時は GitHub API トークンが
# 利用できずレート制限に抵触するため、mise install はスキップする。
# コンテナ作成後にターミナルから手動で実行:
#   mise install --yes
echo "Dev container detected — skipping mise install"
echo "Run 'mise install --yes' manually after container creation"
exit 0
{{ end -}}

max_attempts=3
attempt=1
wait_sec=10

echo "Installing tool versions via mise..."
while [ "$attempt" -le "$max_attempts" ]; do
  if mise install --yes 2>&1; then
    echo "mise install completed successfully"
    break
  fi

  if ! missing_tools_output="$(mise ls --missing 2>/dev/null)"; then
    echo "Warning: failed to inspect missing tools after mise install attempt ${attempt}/${max_attempts}. Retrying..." >&2
    missing_count=1
  else
    missing_count="$(printf '%s\n' "$missing_tools_output" | awk 'index($0, "(missing)") {count++} END {print count+0}')"
  fi

  if [ "$missing_count" -eq 0 ]; then
    echo "All tools installed successfully"
    break
  fi

  if [ "$attempt" -lt "$max_attempts" ]; then
    echo "Attempt ${attempt}/${max_attempts}: ${missing_count} tool(s) remaining. Retrying in ${wait_sec}s..."
    sleep "$wait_sec"
    wait_sec=$((wait_sec * 2))
  fi

  attempt=$((attempt + 1))
done

# SAML SSO ワークアラウンド:
# GitHub Organization が SAML SSO を要求する場合、認証済みの API リクエスト
# （GITHUB_TOKEN 付き）は 403 Forbidden になる。未認証なら公開リポジトリとして
# 正常にアクセスできるため、失敗したツールを認証なしでリトライする。
if ! missing_tools_output="$(mise ls --missing 2>/dev/null)"; then
  echo "Warning: failed to list missing tools for unauthenticated retry. Skipping retry step." >&2
  missing_for_retry=""
else
  missing_for_retry="$(printf '%s\n' "$missing_tools_output" | awk 'index($0, "(missing)") {print $1}')"
fi

if [ -n "$missing_for_retry" ]; then
  echo ""
  echo "Retrying missing tools without GitHub credentials (SAML SSO workaround)..."
  (
    unset GITHUB_TOKEN GH_TOKEN MISE_GITHUB_TOKEN 2>/dev/null
    echo "$missing_for_retry" | while read -r tool; do
      [ -z "$tool" ] && continue
      echo "  Installing $tool (unauthenticated)..."
      if ! mise install "$tool" --yes 2>&1; then
        echo "Warning: failed to install $tool without GitHub credentials. Retry manually with 'mise install $tool --yes'." >&2
      fi
    done
  )
fi

# 最終チェック
if ! missing_tools="$(mise ls --missing 2>/dev/null)"; then
  echo "Warning: failed to inspect final mise installation status. Run 'mise ls --missing' manually." >&2
elif echo "$missing_tools" | grep -q '(missing)'; then
  echo "" >&2
  echo "========================================" >&2
  echo "WARNING: mise install が一部失敗しました" >&2
  echo "========================================" >&2
  echo "$missing_tools" >&2
  echo "" >&2
  echo "リトライ: mise install" >&2
  echo "========================================" >&2
fi
{{ end -}}
