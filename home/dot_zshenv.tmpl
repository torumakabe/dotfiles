{{- /*
zsh は全起動 (login/非login/interactive/非interactive) で .zshenv を読む。
VS Code の非login 統合ターミナル等、login shell を経由しないケースで
mise/user-local ツールを解決するための最小 PATH ブートストラップ。

共通 env (GOPATH, brew shellenv 等) は ~/.profile に集約し、login shell
(~/.zprofile) 経由でのみ適用する設計は維持する。ここでは PATH の共通
エントリだけを .chezmoitemplates/path-bootstrap.sh 経由で共有する。
*/ -}}
{{ includeTemplate "path-bootstrap.sh" . }}
export PATH
