[core]
	autocrlf = input
	fileMode = false
	hooksPath = ~/.config/git/hooks
[pull]
	ff = only
[rerere]
	enabled = true
[fetch]
	prune = true
[format]
	signoff = true
[init]
	defaultBranch = main
[help]
	autocorrect = 20
[alias]
	s = status
	d = diff
	l = log --oneline
[oh-my-zsh]
	hide-status = 1
	hide-dirty = 1
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
[ghq]
	root = ~/workspace
	user = torumakabe
[user]
	name = Toru Makabe
	email = 993850+torumakabe@users.noreply.github.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAILOHG8O9R5bS96Az5RvHDgGtGX1WigZJhZ3CuQnAM7TN
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
# Need to add a public key separately
# echo '993850+torumakabe@users.noreply.github.com ssh-ed25519 [pub-key]' > ~/.ssh/allowed_signers
[commit]
{{- if or .codespaces .devcontainer }}
	gpgsign = false
{{- else }}
	gpgsign = true
{{- end }}
# gitdir matches the repository path prefix, so keep shared defaults here and load
# platform-specific overrides from separate files without duplicating the base config.
# Windows uses explicit drive letters because Git has no drive-agnostic gitdir pattern;
# this setup assumes local clones live on C:/ or D:/ and needs another rule otherwise.
[includeIf "gitdir:~/workspace_corp/"]
	path = ~/.gitconfig-corp
[includeIf "gitdir:/home/"]
	path = ~/.gitconfig-linux
[includeIf "gitdir:/Users/"]
	path = ~/.gitconfig-mac
[includeIf "gitdir/i:C:/"]
	path = ~/.gitconfig-windows
[includeIf "gitdir/i:D:/"]
	path = ~/.gitconfig-windows
