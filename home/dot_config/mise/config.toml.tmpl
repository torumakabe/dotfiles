[tools]
go = "latest"
terraform = "latest"
kubectl = "latest"
helm = "latest"
trivy = "latest"
node = "lts"
uv = "latest"
fzf = "latest"
github-cli = "latest"
dotnet = "latest"
1password = "latest"
cue = "latest"
ghq = "latest"
azure-kubelogin = "latest"
yq = "latest"
sqlc = "latest"
cosign = "latest"
golangci-lint = "latest"
kustomize = "latest"
ripgrep = "latest"
zoxide = "latest"
bat = "latest"
shellcheck = "latest"
gitleaks = "latest"
jq = "latest"
bun = "latest"
"npm:typescript" = "latest"
"npm:typescript-language-server" = "latest"
codex = "latest"
{{ if not (and (eq .chezmoi.os "linux") (eq .chezmoi.arch "arm64")) -}}
# プリビルドバイナリが linux/arm64 未提供のためスキップ
cargo-make = "latest"
{{ end -}}

[settings]
experimental = true
lockfile = true
fetch_remote_versions_timeout = "60s"

[tool_alias]
dotnet = "core:dotnet"
