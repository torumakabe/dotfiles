[tools]
go = "latest"
terraform = "latest"
kubectl = "latest"
helm = "latest"
trivy = "latest"
node = "lts"
uv = "latest"
fzf = "latest"
github-cli = "latest"
dotnet = "latest"
1password = "latest"
goreleaser = "latest"
cue = "latest"
ghq = "latest"
azure-kubelogin = "latest"
yq = "latest"
sqlc = "latest"
cosign = "latest"
golangci-lint = "latest"
kustomize = "latest"
ripgrep = "latest"
zoxide = "latest"
bat = "latest"
shellcheck = "latest"
gitleaks = "latest"
jq = "latest"
rust = "latest"
{{ if ne .chezmoi.os "darwin" -}}
# macOS では github: バックエンドが正しく動作しないため brew で管理
# aqua レジストリが linux/arm64 未対応のため github バックエンドを使用
"github:Azure/azure-dev" = "latest"
{{ end -}}
"github:github/copilot-cli" = "latest"
{{ if ne .chezmoi.os "darwin" -}}
# macOS 向けプリビルドバイナリが未提供のためスキップ
edit = "latest"
{{ end -}}
codex = "latest"
{{ if not (and (eq .chezmoi.os "linux") (eq .chezmoi.arch "arm64")) -}}
# プリビルドバイナリが linux/arm64 未提供のためスキップ
cargo-make = "latest"
{{ end -}}

[settings]
experimental = true
lockfile = true
fetch_remote_versions_timeout = "60s"
