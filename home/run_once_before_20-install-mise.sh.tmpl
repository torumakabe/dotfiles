{{ if ne .chezmoi.os "windows" -}}
#!/bin/bash
set -euo pipefail

# mise — tool version manager
# Order dependency:
# - Keep this after run_once_before_10-install-packages so package-manager prerequisites
#   such as git/zsh are already installed where needed.
# - Keep this before run_once_after_20-mise-install so `mise install` has a bootstrapper.
if command -v mise >/dev/null 2>&1; then
  echo "mise is already installed: $(mise --version)"
  exit 0
fi

{{ if eq .chezmoi.os "darwin" -}}
brew install mise
{{ else -}}
echo "Installing mise..."
curl -fsSL https://mise.run | sh
{{ end -}}
{{ end -}}
